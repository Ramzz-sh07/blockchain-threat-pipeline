# ── Ethereum ──────────────────────────────────────────────
# Get a free key at https://infura.io or https://alchemy.com
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETH_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY

# ── Bitcoin ───────────────────────────────────────────────
# Run a local Bitcoin full node, or use a hosted RPC provider
BTC_RPC_HOST=localhost
BTC_RPC_PORT=8332
BTC_RPC_USER=your_rpc_user
BTC_RPC_PASS=your_rpc_password

# ── Kafka ─────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/blockchain_threats

# ── Model settings ────────────────────────────────────────
RISK_THRESHOLD=70
MODEL_PATH=data/models/isolation_forest.pkl

# ── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
